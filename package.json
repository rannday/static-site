{
  "name": "static-site",
  "version": "0.0.1",
  "description": "Cloudflare static site",
  "repository": {
    "type": "git",
    "url": "https://github.com/rannday/static-site.git"
  },
  "license": "Unlicense",
  "author": "Rann Day",
  "type": "module",
  "scripts": {
    "clean": "del-cli public --force",
    "serve": "eleventy --serve",
    "dev": "cross-env ELEVENTY_ENV=development eleventy --serve",
    "build": "npm run clean && cross-env ELEVENTY_ENV=production eleventy",
    "preview": "cross-env ELEVENTY_ENV=production eleventy --serve --input=public",
    "deploy": "npm run build && wrangler pages deploy public --project-name=rannday"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5",
    "cross-env": "^10.1.0",
    "del-cli": "^7.0.0",
    "esbuild": "^0.28.0",
    "gray-matter": "^4.0.3",
    "html-minifier-next": "^6.1.1",
    "lucide-static": "^1.8.0",
    "wrangler": "^4.81.0"
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "lunr": "^2.3.9"
  }
}
